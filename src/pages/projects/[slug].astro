---
import { getCollection, render } from "astro:content";
import NavBar from "../../layouts/NavBar.astro";
import { Font } from "astro:assets";
import { ClientRouter } from "astro:transitions";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => ({
    params: { slug: project.id.replace(/\.mdx?$/, "") },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const {
  title,
  description,
  heroImage,
  role,
  duration,
  tools,
  github,
  category,
} = project.data;
import "../../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <Font cssVariable="--font-clash-display" />
    <ClientRouter />
  </head>
  <body>
    <NavBar />

    <main>
      <div class="header">
        {category && <p class="category">{category}</p>}
        <h1 class="title">{title}</h1>
      </div>

      {
        heroImage && (
          <div class="hero-image-wrapper">
            <img src={heroImage} alt={title} class="hero-image" />
          </div>
        )
      }

      <div class="meta-row">
        {
          role && (
            <div class="meta-item">
              <span class="meta-label">ROLE</span>
              <span class="meta-value">{role}</span>
            </div>
          )
        }
        {
          duration && (
            <div class="meta-item">
              <span class="meta-label">DURATION</span>
              <span class="meta-value">{duration}</span>
            </div>
          )
        }
        {
          tools && tools.length > 0 && (
            <div class="meta-item">
              <span class="meta-label">TOOLS</span>
              <div class="tools-list">
                {tools.map((tool: string) => (
                  <span class="tool-pill">{tool}</span>
                ))}
              </div>
            </div>
          )
        }
        {
          github && (
            <div class="meta-item">
              <span class="meta-label">GITHUB</span>
              <a href={github} target="_blank" class="github-link">
                View Repository ↗
              </a>
            </div>
          )
        }
      </div>

      <div class="description-row">
        <div class="content-col">
          <Content />
        </div>
      </div>
    </main>
  </body>
</html>

<style>
  body {
    background: black;
    margin: 0;
    padding: 0;
    color: #fff;
    font-family: var(--font-clash-display), sans-serif;
    overflow-y: auto;
    height: auto;
    display: block;
  }

  main {
    max-width: 1100px;
    margin: 0 auto;
    padding: 2rem 2rem 4rem;
  }

  .header {
    margin-bottom: 1.5rem;
    margin-top: 3rem;
  }

  .category {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #999;
    margin: 0 0 0.5rem;
  }

  .title {
    font-size: 3rem;
    font-weight: 700;
    margin: 0;
    line-height: 1.1;
    color: #fff;
  }

  .hero-image-wrapper {
    width: 100%;
    border-radius: 1rem;
    overflow: hidden;
    margin-bottom: 2rem;
  }

  .hero-image {
    width: 100%;
    height: 420px;
    object-fit: cover;
    display: block;
  }

  .meta-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid #eee;
    margin-bottom: 2.5rem;
  }

  .meta-item {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .meta-label {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #999;
  }

  .meta-value {
    font-size: 1rem;
    font-weight: 600;
    color: #fff;
  }

  .tools-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tool-pill {
    background: #111;
    color: white;
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
  }

  .github-link {
    font-size: 1rem;
    font-weight: 600;
    color: #fff;
    text-decoration: none;
  }

  .github-link:hover {
    text-decoration: underline;
  }

  .description-row {
    columns: 2;
    column-gap: 3rem;
  }

  .content-col {
    font-size: 1rem;
    line-height: 1.7;
    color: #fff;
  }

  .content-col p {
    margin: 0 0 1rem;
  }

  @media (max-width: 768px) {
    .meta-row {
      grid-template-columns: 1fr 1fr;
    }
    .description-row {
      columns: 1;
    }
    .title {
      font-size: 2rem;
    }
    .hero-image {
      height: 250px;
    }
  }
</style>
