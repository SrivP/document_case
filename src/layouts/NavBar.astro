---
const { title } = Astro.props;

// props (you can still tweak these here)
const version = "v2.3.1";
const status = "All systems normal";
const color = "#22c55e";
const glowColor = `${color}99`;

import Image from "astro/components/Image.astro";
import arrow from "../assets/arrow.svg";
import wave from "../assets/wave.gif";
import { Font } from "astro:assets";
---

<Font cssVariable="--font-clash-display" />

<nav>
  <a href="/">Home</a>
  <a href="/projects">Projects</a>
  <div class="contact-wrapper">
    <a href="/contact">Contact</a>

    <div class="contact-arrow">
      <Image src={arrow} alt="arrow" width={40} height={40} />
      <Image
        id="contact"
        src={wave}
        alt="penguin waving"
        width={40}
        height={40}
      />
    </div>
  </div>
</nav>

<!-- Status Badge (bottom-left) -->
<div class="status-wrapper" style={`--color: ${color}; --glow: ${glowColor};`}>
  <div class="glow"></div>
  <div class="badge"></div>

  <div class="tooltip">
    <p><strong>Version:</strong> {version}</p>
    <p>{status}</p>
  </div>
</div>

<style>
  p {
    font-family: var(--font-clash-display);
    font-weight: 400;
  }
  nav {
    display: flex;
    gap: 2rem;
    padding: 1rem 2rem;
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    z-index: 100;
  }

  nav a {
    color: white;
    text-decoration: none;
    font-family: var(--font-clash-display);
    font-weight: 600;
  }

  /* ✅ Bottom-left positioning */
  .status-wrapper {
    position: fixed; /* use fixed so it stays on screen */
    bottom: 20px;
    left: 20px;

    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 100;
  }

  .glow {
    position: absolute;
    width: 32px;
    height: 32px;
    background: radial-gradient(circle, var(--glow), transparent 70%);
    filter: blur(14px);
    opacity: 0.7;
    animation: pulse 2.5s infinite ease-in-out;
    transition: all 0.3s ease;
  }

  .badge {
    width: 10px;
    height: 10px;
    background: var(--color);
    border-radius: 999px;
    box-shadow: 0 0 10px var(--color);
    transition: transform 0.2s ease;
  }

  .tooltip {
    position: absolute;
    bottom: 160%;
    left: 0; /* align to left instead of center */
    transform: scale(0.95);
    background: rgba(10, 10, 10, 0.75);
    backdrop-filter: blur(10px);
    color: #d1d5db;
    padding: 8px 12px;
    border-radius: 10px;
    font-size: 12px;
    white-space: nowrap;
    border: 1px solid rgba(255, 255, 255, 0.08);

    opacity: 0;
    pointer-events: none;
    transition: all 0.2s ease;
  }

  .tooltip::after {
    content: "";
    position: absolute;
    top: 100%;
    left: 10px; /* aligns arrow nicely with left edge */
    border: 6px solid transparent;
    border-top-color: rgba(10, 10, 10, 0.75);
  }

  .status-wrapper:hover .tooltip {
    opacity: 1;
    transform: scale(1);
  }

  .status-wrapper:hover .glow {
    opacity: 1;
    transform: scale(1.15);
  }

  .status-wrapper:hover .badge {
    transform: translateY(-1px);
  }

  @keyframes pulse {
    0%,
    100% {
      opacity: 0.6;
      transform: scale(1);
    }
    50% {
      opacity: 1;
      transform: scale(1.2);
    }
  }

  #contact {
    background-color: white;
    border-radius: 16px;
  }

  .contact-wrapper {
    position: relative;
    display: inline-block;
  }

  .contact-arrow {
    position: absolute;
    top: 120%; /* pushes it below the text */
    left: 100%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: row;
    gap: 4px;
  }
</style>
